#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CAPTAIN_ROOT="$(cd "$BIN_DIR/../.." && pwd)"
HARNESS_SCRIPT="$CAPTAIN_ROOT/captain/harnesses/rust-harness/scripts/harness.sh"

usage() {
  cat <<'EOF'
Captain CLI

Usage:
  captain hermes <prompt> [options]
  captain openclaw <prompt> [options]
  captain shell <prompt> [options]
  captain cargo <prompt> [options]
  captain code --executor <executor> [--prompt <prompt>] [options]
  captain status

Agent shortcuts:
  captain hermes <prompt>      Run a governed Hermes coding session
  captain openclaw <prompt>    Run a governed OpenClaw coding session
  captain shell <prompt>       Run a governed shell/local coding session
  captain cargo <prompt>       Run a governed cargo/local coding session

Common options:
  --repo <path>                         Target repository (default: .)
  --time <duration>                     Timebox, e.g. 45m, 1h, 3600 (default: 1h)
  --runtime-log-file <path>             Human-readable runtime stream
  --thought-log-file <path>             Markdown thought log
  --heartbeat-sec <seconds>             Phase heartbeat interval
  --cycle-pause-sec <seconds>           Pause between cycles
  --noop-streak-limit <n>               Force mutation after N no-op cycles
  --conformance-interval-unchanged <n>  Run conformance every N unchanged cycles
  --progress-file <path>                Coding progress state path
  --run-lock-file <path>                Repo single-instance lock path
  --prompt-file <path>                  Read prompt from file instead of positional prompt
  --commit-each-cycle                   Attempt commit hook each cycle
  --push-each-cycle                     Attempt push after commit; off by default
  --dry-run | --print-command           Print resolved harness command without running
  -h, --help                            Show help

Examples:
  captain hermes "fix the failing tests" --repo . --time 45m --commit-each-cycle
  captain openclaw "implement issue #12" --repo ~/repo --time 1h --runtime-log-file runs/openclaw.log
  captain code --executor hermes --prompt "ship useful code" --repo . --time 30m

Install for interactive use:
  export PATH="$PWD/captain/bin:$PATH"
EOF
}

shell_join_pretty() {
  local out=""
  local arg
  for arg in "$@"; do
    if [[ -z "$out" ]]; then
      out="$arg"
    else
      out+=" $arg"
    fi
  done
  printf '%s\n' "$out"
}

shell_join_quoted() {
  local out=""
  local arg quoted
  for arg in "$@"; do
    printf -v quoted '%q' "$arg"
    if [[ -z "$out" ]]; then
      out="$quoted"
    else
      out+=" $quoted"
    fi
  done
  printf '%s\n' "$out"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  status)
    shift
    exec cargo run --manifest-path "$CAPTAIN_ROOT/captain/harnesses/rust-harness/Cargo.toml" --quiet -- status "$@"
    ;;
esac

SUBCOMMAND="$1"
shift

EXECUTOR=""
PROMPT=""
PROMPT_FILE=""
REPO="."
TIME_INPUT="1h"
DRY_RUN=0
FORWARD=()

case "$SUBCOMMAND" in
  hermes|openclaw|shell|cargo)
    EXECUTOR="$SUBCOMMAND"
    if [[ $# -gt 0 && "${1:-}" != --* ]]; then
      PROMPT="$1"
      shift
    fi
    ;;
  code)
    ;;
  *)
    echo "Unknown command: $SUBCOMMAND" >&2
    usage >&2
    exit 64
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO="${2:-}"; shift 2 ;;
    --time)
      TIME_INPUT="${2:-}"; shift 2 ;;
    --executor)
      EXECUTOR="${2:-}"; shift 2 ;;
    --prompt)
      PROMPT="${2:-}"; shift 2 ;;
    --prompt-file)
      PROMPT_FILE="${2:-}"; shift 2 ;;
    --runtime-log-file|--thought-log-file|--heartbeat-sec|--cycle-pause-sec|--noop-streak-limit|--conformance-interval-unchanged|--progress-file|--run-lock-file)
      FORWARD+=("$1" "${2:-}"); shift 2 ;;
    --commit-each-cycle|--push-each-cycle)
      FORWARD+=("$1"); shift ;;
    --dry-run|--print-command)
      DRY_RUN=1; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        FORWARD+=("$1")
        shift
      done
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

if [[ -z "$EXECUTOR" ]]; then
  echo "Missing --executor for 'captain code'." >&2
  usage >&2
  exit 64
fi

if [[ -n "$PROMPT" && -n "$PROMPT_FILE" ]]; then
  echo "Use either a positional/--prompt value or --prompt-file, not both." >&2
  exit 64
fi

CMD=(
  bash "$HARNESS_SCRIPT"
  --repo "$REPO"
  --time "$TIME_INPUT"
  --executor "$EXECUTOR"
)

if [[ -n "$PROMPT" ]]; then
  CMD+=(--prompt "$PROMPT")
elif [[ -n "$PROMPT_FILE" ]]; then
  CMD+=(--prompt-file "$PROMPT_FILE")
fi

CMD+=("${FORWARD[@]}")

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "captain.resolved_command=$(shell_join_pretty "${CMD[@]}")"
  echo "captain.resolved_command_quoted=$(shell_join_quoted "${CMD[@]}")"
  exit 0
fi

exec "${CMD[@]}"
